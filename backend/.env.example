# Altere para a URL do seu PostgreSQL (Supabase, Neon, Railway, etc.)
DATABASE_URL="postgresql://usuario:senha@host:5432/rastreador"

# Gere uma chave secreta com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="coloque-uma-chave-secreta-aqui"

# Porta do servidor
PORT=3001
